<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_glossy_main"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Dialer Settings"
        android:textColor="#F7FCFF"
        android:textSize="24sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="Set your custom IVR number"
        android:textColor="#BEE2F5FF"
        android:textSize="13sp" />

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        app:cardBackgroundColor="#2A152A3C"
        app:cardCornerRadius="18dp"
        app:cardElevation="0dp"
        app:strokeColor="#52B6E6FF"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="IVR Number"
                android:textColor="#EFF9FF"
                android:textSize="14sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/ivrInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_frost_input"
                android:hint="Ex: *99#"
                android:inputType="phone"
                android:padding="12dp"
                android:textColor="#F3FBFF"
                android:textColorHint="#95CDE8F6" />

            <Button
                android:id="@+id/saveButton"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_primary_button"
                android:text="Save IVR"
                android:textAllCaps="false"
                android:textColor="#F7FDFF"
                android:textStyle="bold" />

            <Button
                android:id="@+id/resetButton"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_frost_button"
                android:text="Reset"
                android:textAllCaps="false"
                android:textColor="#DBF3FF" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</LinearLayout>
