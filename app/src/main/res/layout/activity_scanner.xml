<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    tools:context=".ScannerActivity">

    <TextureView
        android:id="@+id/cameraTexture"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <com.example.minimalupi.ScannerOverlayView
        android:id="@+id/scannerOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="18dp"
        android:paddingTop="18dp"
        android:paddingEnd="18dp">

        <ImageButton
            android:id="@+id/backButton"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:background="@drawable/bg_frost_circle"
            android:contentDescription="Back"
            android:padding="10dp"
            android:src="@android:drawable/ic_media_previous"
            android:tint="#E7F8FF" />

        <TextView
            android:id="@+id/scannerTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_weight="1"
            android:text="Scan to Pay"
            android:textColor="#F6FCFF"
            android:textSize="20sp"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/historyButton"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:background="@drawable/bg_frost_circle"
            android:contentDescription="@string/history"
            android:padding="10dp"
            android:src="@android:drawable/ic_menu_recent_history"
            android:tint="#E7F8FF" />
    </LinearLayout>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/paymentPreviewCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="90dp"
        app:cardBackgroundColor="#2D11222D"
        app:cardCornerRadius="20dp"
        app:cardElevation="0dp"
        app:strokeColor="#55D2F2FF"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="16dp">

            <View
                android:layout_width="9dp"
                android:layout_height="9dp"
                android:background="@drawable/bg_status_dot" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Secure Payment Scan"
                    android:textColor="#F4FCFF"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Align QR inside frame to continue"
                    android:textColor="#C5E7F2FF"
                    android:textSize="12sp" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Live"
                android:textAllCaps="true"
                android:textColor="#B8F2FF"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingBottom="22dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/scan_bottom_hint"
            android:textColor="#CCEDF6FF"
            android:textSize="13sp" />
    </LinearLayout>

</FrameLayout>
